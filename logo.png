/* ==========================================================================
   ZUCKEL AG — SHARED DESIGN SYSTEM
   Used by every page. Keep this file in sync across the whole site.
   ========================================================================== */

:root{
  --bg-0:#080B14;
  --bg-1:#0D1326;
  --surface:#121A30;
  --surface-2:#161F3A;
  --border:rgba(110,160,255,0.16);
  --border-strong:rgba(110,160,255,0.32);
  --text-0:#E9EEFC;
  --text-1:#A9B6D6;
  --text-2:#6E7CA0;
  --accent-1:#3B6FF0;
  --accent-2:#4FD3FF;
  --accent-3:#7C6FF0;
  --accent-4:#5EEAD4;
  --accent-5:#A78BFA;
  --accent-6:#2447A8;
  --available-fg:#5B6B8C;
  --available-bg:#1A2238;
  --danger:#F87171;
  --success:#4ADE80;
  --warning:#FBBF24;
  --radius:14px;
  --radius-sm:8px;
  --font-display:'Space Grotesk', 'Arial Narrow', sans-serif;
  --font-mono:'IBM Plex Mono', 'SFMono-Regular', Consolas, monospace;
  --font-body:-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

*{ box-sizing:border-box; }
html,body{ margin:0; padding:0; }
body{
  min-height:100vh;
  background:
    radial-gradient(circle at 18% -10%, rgba(79,211,255,0.10), transparent 45%),
    radial-gradient(circle at 100% 10%, rgba(124,111,240,0.10), transparent 40%),
    linear-gradient(180deg, var(--bg-0), var(--bg-1) 60%, var(--bg-0));
  background-attachment:fixed;
  color:var(--text-0);
  font-family:var(--font-body);
  line-height:1.5;
}

a{ color:inherit; text-decoration:none; }
ul{ list-style:none; margin:0; padding:0; }
button{ font-family:inherit; }
img{ max-width:100%; }

.page{
  max-width:1120px;
  margin:0 auto;
  padding:0 24px 60px;
}

/* ---------- Top navigation ---------- */
.topnav{
  position:sticky;
  top:0;
  z-index:40;
  background:rgba(8,11,20,0.85);
  backdrop-filter:blur(8px);
  border-bottom:1px solid var(--border);
  margin-bottom:28px;
}
.topnav-inner{
  max-width:1120px;
  margin:0 auto;
  padding:0 24px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  height:62px;
  gap:16px;
}
.topnav-brand{
  display:flex;
  align-items:center;
  gap:10px;
  flex-shrink:0;
}
.topnav-brand img{ height:24px; display:block; }
.topnav-brand span{
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.12em;
  color:var(--text-2);
  white-space:nowrap;
}
.topnav-links{
  display:flex;
  align-items:center;
  gap:4px;
  flex-wrap:nowrap;
  overflow-x:auto;
  scrollbar-width:none;
}
.topnav-links::-webkit-scrollbar{ display:none; }
.topnav-links a{
  font-size:13.5px;
  font-weight:500;
  color:var(--text-1);
  padding:8px 12px;
  border-radius:7px;
  white-space:nowrap;
  transition:background 0.15s, color 0.15s;
}
.topnav-links a:hover{ color:var(--text-0); background:var(--surface-2); }
.topnav-links a.active{
  color:var(--accent-2);
  background:rgba(79,211,255,0.08);
}
.topnav-admin{ flex-shrink:0; }

/* mobile nav toggle (hidden on desktop) */
.nav-toggle{
  display:none;
  background:var(--surface-2);
  border:1px solid var(--border-strong);
  border-radius:7px;
  color:var(--text-0);
  width:36px; height:36px;
  align-items:center;
  justify-content:center;
  cursor:pointer;
  flex-shrink:0;
}
@media (max-width:760px){
  .nav-toggle{ display:flex; }
  .topnav-links{
    position:absolute;
    top:62px; left:0; right:0;
    background:var(--bg-1);
    border-bottom:1px solid var(--border);
    flex-direction:column;
    align-items:stretch;
    padding:8px 16px 14px;
    display:none;
    gap:2px;
  }
  .topnav-links.open{ display:flex; }
  .topnav-links a{ padding:10px 12px; }
}

/* ---------- Page header (per-page hero strip) ---------- */
.page-header{
  position:relative;
  display:flex;
  align-items:flex-end;
  justify-content:space-between;
  gap:20px;
  flex-wrap:wrap;
  padding:22px 26px;
  border:1px solid var(--border);
  border-radius:var(--radius);
  background:linear-gradient(135deg, var(--surface), var(--surface-2));
  overflow:hidden;
  isolation:isolate;
  margin-bottom:20px;
}
.page-header::before{
  content:"";
  position:absolute;
  inset:0;
  background:repeating-linear-gradient(
    0deg,
    rgba(255,255,255,0.05) 0px, rgba(255,255,255,0.05) 1px,
    transparent 1px, transparent 6px
  );
  opacity:0.3;
  mix-blend-mode:screen;
  pointer-events:none;
  z-index:0;
}
.page-header .eyebrow{
  margin:0 0 4px;
  font-family:var(--font-mono);
  font-size:11.5px;
  letter-spacing:0.14em;
  text-transform:uppercase;
  color:var(--accent-2);
  z-index:1;
}
.page-header h1{
  margin:0;
  font-family:var(--font-display);
  font-weight:700;
  font-size:clamp(26px, 4vw, 34px);
  letter-spacing:-0.01em;
  z-index:1;
}
.page-header p.lede{
  margin:8px 0 0;
  max-width:560px;
  color:var(--text-1);
  font-size:14.5px;
  z-index:1;
}
.title-block{ z-index:1; }
.stamp{
  z-index:1;
  align-self:flex-start;
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.12em;
  font-weight:600;
  color:var(--danger);
  border:1px solid rgba(248,113,113,0.5);
  padding:5px 10px;
  border-radius:6px;
  transform:rotate(-3deg);
  background:rgba(248,113,113,0.06);
  white-space:nowrap;
}

/* ---------- Generic panel / card ---------- */
.panel{
  border:1px solid var(--border);
  border-radius:var(--radius);
  background:var(--surface);
  padding:22px;
}
.panel + .panel{ margin-top:20px; }

.card-grid{
  display:grid;
  grid-template-columns:repeat(auto-fill, minmax(240px, 1fr));
  gap:16px;
}
.card{
  border:1px solid var(--border);
  border-radius:var(--radius);
  background:var(--surface);
  padding:18px;
  display:flex;
  flex-direction:column;
  gap:8px;
}
.card h3{
  margin:0;
  font-family:var(--font-display);
  font-size:16px;
  font-weight:600;
}
.card p{
  margin:0;
  font-size:13.5px;
  color:var(--text-1);
}
.card .meta{
  font-family:var(--font-mono);
  font-size:11px;
  color:var(--text-2);
}

/* ---------- Section heads ---------- */
.section-head{
  display:flex;
  align-items:baseline;
  justify-content:space-between;
  gap:10px;
  margin-bottom:14px;
  flex-wrap:wrap;
}
.section-head h2{
  margin:0;
  font-family:var(--font-display);
  font-size:18px;
  font-weight:600;
}
.muted{ color:var(--text-2); font-size:12.5px; }

/* ---------- Badges ---------- */
.badge{
  display:inline-flex;
  align-items:center;
  gap:5px;
  font-family:var(--font-mono);
  font-size:10.5px;
  letter-spacing:0.06em;
  text-transform:uppercase;
  padding:3px 8px;
  border-radius:5px;
  border:1px solid var(--border-strong);
  color:var(--text-1);
  white-space:nowrap;
}
.badge.active{ color:var(--success); border-color:rgba(74,222,128,0.4); background:rgba(74,222,128,0.08); }
.badge.building{ color:var(--warning); border-color:rgba(251,191,36,0.4); background:rgba(251,191,36,0.08); }
.badge.planned{ color:var(--text-1); }
.badge.inactive{ color:var(--text-2); }

/* ---------- Table (ledger style) ---------- */
.table-wrap{ overflow-x:auto; }
table.ledger{
  width:100%;
  border-collapse:collapse;
  font-size:14px;
}
table.ledger th{
  text-align:left;
  font-family:var(--font-mono);
  font-size:10.5px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--text-2);
  padding:0 10px 10px;
  border-bottom:1px solid var(--border-strong);
  white-space:nowrap;
}
table.ledger td{
  padding:11px 10px;
  border-bottom:1px solid var(--border);
  vertical-align:middle;
}
table.ledger tr:last-child td{ border-bottom:none; }
table.ledger input{
  background:var(--surface-2);
  border:1px solid var(--border-strong);
  border-radius:6px;
  color:var(--text-0);
  font-family:inherit;
  font-size:13px;
  padding:6px 8px;
  width:100%;
  min-width:90px;
}
table.ledger input:focus-visible{
  outline:2px solid var(--accent-2);
  outline-offset:1px;
}

/* ---------- Forms ---------- */
.field{
  display:flex;
  flex-direction:column;
  gap:5px;
}
.field label{
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.06em;
  text-transform:uppercase;
  color:var(--text-2);
}
.field input, .field textarea, .field select{
  background:var(--surface-2);
  border:1px solid var(--border-strong);
  border-radius:8px;
  color:var(--text-0);
  font-family:inherit;
  font-size:14px;
  padding:9px 11px;
  width:100%;
}
.field input:focus-visible, .field textarea:focus-visible, .field select:focus-visible{
  outline:2px solid var(--accent-2);
  outline-offset:1px;
}
.field-row{
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(160px, 1fr));
  gap:12px;
}

/* ---------- Buttons ---------- */
.btn-primary, .btn-secondary, .btn-ghost, .btn-danger{
  border-radius:8px;
  padding:9px 16px;
  font-size:13px;
  font-weight:500;
  cursor:pointer;
  border:1px solid transparent;
  display:inline-flex;
  align-items:center;
  gap:6px;
}
.btn-primary{
  background:linear-gradient(135deg, var(--accent-1), var(--accent-3));
  color:#fff;
}
.btn-primary:disabled{ opacity:0.4; cursor:not-allowed; }
.btn-secondary{
  background:var(--surface-2);
  border:1px solid var(--border-strong);
  color:var(--text-0);
}
.btn-ghost{
  background:transparent;
  border:1px solid var(--border-strong);
  color:var(--text-1);
}
.btn-danger{
  background:rgba(248,113,113,0.1);
  border:1px solid rgba(248,113,113,0.4);
  color:#FCA5A5;
}
.btn-icon{
  width:28px; height:28px;
  border-radius:6px;
  border:1px solid var(--border-strong);
  background:var(--surface-2);
  color:var(--danger);
  cursor:pointer;
  font-size:13px;
  line-height:1;
  display:flex;
  align-items:center;
  justify-content:center;
  flex-shrink:0;
}
.btn-icon:hover{ background:rgba(248,113,113,0.12); }
.btn-primary:focus-visible, .btn-secondary:focus-visible, .btn-ghost:focus-visible,
.btn-danger:focus-visible, .btn-icon:focus-visible{
  outline:2px solid var(--accent-2);
  outline-offset:2px;
}

/* ---------- Admin badge ---------- */
.admin-badge{
  font-family:var(--font-mono);
  font-size:11px;
  letter-spacing:0.1em;
  color:var(--success);
  border:1px solid rgba(74,222,128,0.4);
  background:rgba(74,222,128,0.08);
  padding:5px 9px;
  border-radius:6px;
  white-space:nowrap;
}

/* ---------- Empty / loading states ---------- */
.empty-state, .loading-state{
  text-align:center;
  padding:36px 18px;
  color:var(--text-2);
  font-size:13.5px;
}
.empty-state .big-icon, .loading-state .big-icon{
  font-size:26px;
  display:block;
  margin-bottom:8px;
  opacity:0.6;
}

/* ---------- Warning banner ---------- */
.warning{
  margin-top:12px;
  padding:10px 12px;
  border-radius:8px;
  border:1px solid rgba(248,113,113,0.4);
  background:rgba(248,113,113,0.08);
  color:#FCA5A5;
  font-size:13px;
  font-family:var(--font-mono);
}
.notice{
  margin-top:12px;
  padding:10px 12px;
  border-radius:8px;
  border:1px solid var(--border-strong);
  background:var(--surface-2);
  color:var(--text-1);
  font-size:13px;
}
.hidden{ display:none !important; }

/* ---------- Footer ---------- */
.site-footer{
  margin-top:20px;
  display:flex;
  align-items:center;
  justify-content:space-between;
  gap:16px;
  flex-wrap:wrap;
  padding:16px 22px;
  border:1px solid var(--border);
  border-radius:var(--radius);
  background:var(--surface);
}
.footer-controls{
  display:flex;
  align-items:center;
  gap:10px;
  flex-wrap:wrap;
}
.legal{
  text-align:center;
  margin-top:18px;
  font-size:11.5px;
  color:var(--text-2);
}

/* ---------- Overlay / modal ---------- */
.overlay{
  position:fixed;
  inset:0;
  background:rgba(5,8,16,0.7);
  backdrop-filter:blur(3px);
  display:flex;
  align-items:center;
  justify-content:center;
  padding:20px;
  z-index:50;
}
.modal{
  width:100%;
  max-width:380px;
  background:var(--surface-2);
  border:1px solid var(--border-strong);
  border-radius:var(--radius);
  padding:24px;
}
.modal h2{ margin:0 0 6px; font-family:var(--font-display); font-size:18px; }
.modal p{ margin:0 0 16px; }
.modal .field{ margin-bottom:10px; }
.modal .error{ color:var(--danger); font-size:12.5px; margin-bottom:8px; }
.modal-actions{ display:flex; justify-content:flex-end; gap:8px; margin-top:10px; }

/* ---------- Toast ---------- */
.toast{
  position:fixed;
  bottom:24px;
  left:50%;
  transform:translateX(-50%) translateY(10px);
  background:var(--surface-2);
  border:1px solid var(--border-strong);
  color:var(--text-0);
  padding:10px 18px;
  border-radius:8px;
  font-size:13px;
  opacity:0;
  transition:opacity 0.25s ease, transform 0.25s ease;
  pointer-events:none;
  z-index:60;
  max-width:90vw;
}
.toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }
.toast.error{ border-color:rgba(248,113,113,0.5); color:#FCA5A5; }

/* ---------- Hero (home page) ---------- */
.hero{
  display:flex;
  flex-direction:column;
  align-items:flex-start;
  gap:14px;
  padding:40px 30px;
}
.hero img.hero-logo{ height:54px; margin-bottom:8px; }
.hero h1{
  margin:0;
  font-family:var(--font-display);
  font-weight:700;
  font-size:clamp(28px, 5vw, 42px);
  max-width:680px;
}
.hero p.lede{
  margin:0;
  max-width:560px;
  color:var(--text-1);
  font-size:15.5px;
}
.stat-row{
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(140px, 1fr));
  gap:14px;
  margin-top:8px;
}
.stat{
  border:1px solid var(--border);
  border-radius:var(--radius-sm);
  background:var(--surface-2);
  padding:14px 16px;
}
.stat .num{
  display:block;
  font-family:var(--font-mono);
  font-size:24px;
  font-weight:600;
  color:var(--accent-2);
}
.stat .lbl{
  display:block;
  font-family:var(--font-mono);
  font-size:10.5px;
  letter-spacing:0.08em;
  text-transform:uppercase;
  color:var(--text-2);
  margin-top:2px;
}

@media (prefers-reduced-motion:no-preference){
  .sweep{ animation:sweep 9s linear infinite; transform-origin:160px 160px; }
}
@keyframes sweep{ to{ transform:rotate(360deg); } }

/* ---------- Big value display (valuation page) ---------- */
.big-value{
  font-family:var(--font-mono);
  font-weight:600;
  font-size:48px;
  color:var(--text-0);
  line-height:1;
}
.big-value .unit{ font-size:20px; color:var(--text-2); margin-left:8px; }
.delta{ font-family:var(--font-mono); font-size:13px; margin-top:6px; }
.delta.up{ color:var(--success); }
.delta.down{ color:var(--danger); }
.delta.flat{ color:var(--text-2); }
.linechart-wrap svg{ width:100%; height:auto; display:block; }

/* ---------- Shares / donut chart (Investor Relations) ---------- */
.layout{
  display:grid;
  grid-template-columns:380px 1fr;
  gap:20px;
  align-items:start;
}
@media (max-width:860px){ .layout{ grid-template-columns:1fr; } }

.chart-panel{
  display:flex;
  flex-direction:column;
  align-items:center;
  gap:14px;
}
.chart-wrap{ position:relative; width:100%; max-width:300px; }
.chart-wrap svg{ width:100%; height:auto; display:block; }

.readout{
  position:absolute;
  top:50%; left:50%;
  transform:translate(-50%,-50%);
  text-align:center;
  pointer-events:none;
}
.readout .big{
  display:block;
  font-family:var(--font-mono);
  font-weight:600;
  font-size:30px;
  color:var(--text-0);
}
.readout .label{
  display:block;
  font-family:var(--font-mono);
  font-size:10px;
  letter-spacing:0.14em;
  color:var(--text-2);
  margin-top:2px;
}
.readout .sub{
  display:block;
  font-family:var(--font-mono);
  font-size:11.5px;
  color:var(--accent-2);
  margin-top:6px;
}
.legend-hint{ font-family:var(--font-mono); font-size:11px; color:var(--text-2); text-align:center; }

.holder-list{ list-style:none; margin:0; padding:0; display:flex; flex-direction:column; gap:2px; }
.holder-row{
  display:grid;
  grid-template-columns:14px 1fr auto auto;
  align-items:center;
  gap:12px;
  padding:11px 6px;
  border-bottom:1px solid var(--border);
}
.holder-row.editing{ grid-template-columns:14px 1fr 90px 84px 28px; }
.holder-row:last-of-type{ border-bottom:none; }
.holder-row.available{ opacity:0.85; }

.swatch{ width:11px; height:11px; border-radius:3px; flex-shrink:0; }
.swatch.available{
  background-image:repeating-linear-gradient(45deg, var(--available-fg) 0 3px, var(--available-bg) 3px 7px);
}
.holder-name{ font-weight:500; font-size:14.5px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
.holder-role{ font-family:var(--font-mono); font-size:11.5px; color:var(--text-1); white-space:nowrap; }
.holder-pct{ font-family:var(--font-mono); font-size:14.5px; font-weight:500; text-align:right; min-width:58px; }

.holder-row input{
  background:var(--surface-2);
  border:1px solid var(--border-strong);
  border-radius:6px;
  color:var(--text-0);
  font-family:inherit;
  font-size:13px;
  padding:6px 8px;
  width:100%;
  min-width:0;
}
.holder-row input.input-pct{ font-family:var(--font-mono); text-align:right; }
.holder-row input:focus-visible{ outline:2px solid var(--accent-2); outline-offset:1px; }
.add-row{ padding-top:12px; }
